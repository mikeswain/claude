  @Nested
  class MultiTypeHandling {

    @Test
    void testMultipleTypesWithArrayRestrictionCreatesComposedSchema() {
      // Multi-type properties with union/intersection restrictions create composed schemas
      // Note: This requires an array-implying restriction to work correctly
      OWLDataProperty prop = df.getOWLDataProperty("http://example.org/", "prop");
      RestrictionInfo.DataSomeValuesFrom someValuesFrom = new RestrictionInfo.DataSomeValuesFrom(
          df.getOWLDataSomeValuesFrom(prop, df.getStringOWLDatatype()));
      RestrictionInfo.UnionOf unionOf = new RestrictionInfo.UnionOf(
          df.getOWLObjectUnionOf(
              df.getOWLClass("http://example.org/", "A"),
              df.getOWLClass("http://example.org/", "B")));

      DataPropertyMapper mapper = new DataPropertyMapper(
          config, "testProp", "Test Property", "Description",
          null, Set.of(someValuesFrom, unionOf), Collections.emptyList(),
          List.of("string", "integer"));

      Schema<?> schema = mapper.getSchemaByDataProperty();

      assertInstanceOf(ArraySchema.class, schema);
      ArraySchema arraySchema = (ArraySchema) schema;
      assertInstanceOf(ComposedSchema.class, arraySchema.getItems());
      ComposedSchema composedSchema = (ComposedSchema) arraySchema.getItems();
      assertNotNull(composedSchema.getAnyOf());
      assertEquals(2, composedSchema.getAnyOf().size());
    }

    @Test
    void testMultipleTypesWithIntersectionCreatesAllOf() {
      OWLDataProperty prop = df.getOWLDataProperty("http://example.org/", "prop");
      RestrictionInfo.DataSomeValuesFrom someValuesFrom = new RestrictionInfo.DataSomeValuesFrom(
          df.getOWLDataSomeValuesFrom(prop, df.getStringOWLDatatype()));
      RestrictionInfo.IntersectionOf intersectionOf = new RestrictionInfo.IntersectionOf(
          df.getOWLObjectIntersectionOf(
              df.getOWLClass("http://example.org/", "A"),
              df.getOWLClass("http://example.org/", "B")));

      DataPropertyMapper mapper = new DataPropertyMapper(
          config, "testProp", "Test Property", "Description",
          null, Set.of(someValuesFrom, intersectionOf), Collections.emptyList(),
          List.of("string", "integer"));

      Schema<?> schema = mapper.getSchemaByDataProperty();

      assertInstanceOf(ArraySchema.class, schema);
      ArraySchema arraySchema = (ArraySchema) schema;
      assertInstanceOf(ComposedSchema.class, arraySchema.getItems());
      ComposedSchema composedSchema = (ComposedSchema) arraySchema.getItems();
      assertNotNull(composedSchema.getAllOf());
      assertEquals(2, composedSchema.getAllOf().size());
    }
  }

