package regression.features.datatypes;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;

import com.grl.TestUtil;
import com.jayway.jsonpath.ReadContext;
import org.junit.jupiter.api.BeforeAll;
import org.junit.jupiter.api.Test;

/**
 * Integration tests for XSD datatype to OpenAPI type mappings.
 * Tests that each XSD datatype is correctly mapped to OpenAPI type and format.
 */
public class DatatypeMappingsIT {

  private static ReadContext spec;
  private static final String SCHEMA_PATH = "$.components.schemas.DatatypesTest.properties";

  @BeforeAll
  static void setup() {
    spec = TestUtil.getGeneratedSpec(
        TestUtil.asFilePath(DatatypeMappingsIT.class, "/regression/configs/config_datatypes.yaml"));
  }

  @Test
  void stringMapsToString() {
    assertEquals("string", spec.read(SCHEMA_PATH + ".stringProp.type"));
  }

  @Test
  void integerMapsToInteger() {
    assertEquals("integer", spec.read(SCHEMA_PATH + ".integerProp.type"));
  }

  @Test
  void decimalMapsToNumber() {
    assertEquals("number", spec.read(SCHEMA_PATH + ".decimalProp.type"));
  }

  @Test
  void booleanMapsToBoolean() {
    assertEquals("boolean", spec.read(SCHEMA_PATH + ".booleanProp.type"));
  }

  @Test
  void dateTimeMapsToStringWithFormat() {
    assertEquals("string", spec.read(SCHEMA_PATH + ".dateTimeProp.type"));
    assertEquals("date-time", spec.read(SCHEMA_PATH + ".dateTimeProp.format"));
  }

  @Test
  void dateMapsToStringWithDateFormat() {
    assertEquals("string", spec.read(SCHEMA_PATH + ".dateProp.type"));
    // Note: date format may vary based on implementation
  }

  @Test
  void timeMapsToString() {
    assertEquals("string", spec.read(SCHEMA_PATH + ".timeProp.type"));
  }

  @Test
  void anyURIMapsToString() {
    // Note: anyURI currently maps to string without uri format
    assertEquals("string", spec.read(SCHEMA_PATH + ".anyURIProp.type"));
  }

  @Test
  void doubleMapsToNumber() {
    assertEquals("number", spec.read(SCHEMA_PATH + ".doubleProp.type"));
  }

  @Test
  void floatMapsToNumber() {
    assertEquals("number", spec.read(SCHEMA_PATH + ".floatProp.type"));
  }

  @Test
  void longMapsToInteger() {
    assertEquals("integer", spec.read(SCHEMA_PATH + ".longProp.type"));
  }

  @Test
  void durationMapsToString() {
    assertEquals("string", spec.read(SCHEMA_PATH + ".durationProp.type"));
  }

  @Test
  void schemaHasCorrectStructure() {
    assertEquals("object", spec.read("$.components.schemas.DatatypesTest.type"));
    assertEquals("Datatypes Test", spec.read("$.components.schemas.DatatypesTest.title"));
    assertNotNull(spec.read("$.components.schemas.DatatypesTest.properties.apiID"));
  }

  @Test
  void allPropertiesHaveTitles() {
    assertEquals("String Prop", spec.read(SCHEMA_PATH + ".stringProp.title"));
    assertEquals("Integer Prop", spec.read(SCHEMA_PATH + ".integerProp.title"));
    assertEquals("Boolean Prop", spec.read(SCHEMA_PATH + ".booleanProp.title"));
    assertEquals("Date Time Prop", spec.read(SCHEMA_PATH + ".dateTimeProp.title"));
    assertEquals("Any URI Prop", spec.read(SCHEMA_PATH + ".anyURIProp.title"));
  }
}
