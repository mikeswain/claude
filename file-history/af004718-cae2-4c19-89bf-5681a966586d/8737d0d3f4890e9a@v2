<?xml version="1.0"?>
<rdf:RDF xmlns="https://example.com/cardinality/"
     xml:base="https://example.com/cardinality/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:base="https://www.graphresearchlabs.com/base/"
     xmlns:api="https://www.graphresearchlabs.com/">

    <owl:Ontology rdf:about="https://example.com/cardinality/">
        <owl:imports rdf:resource="https://www.graphresearchlabs.com/base/V1.0.2"/>
        <rdfs:comment>Test ontology for cardinality restrictions.</rdfs:comment>
    </owl:Ontology>

    <!-- APIRoot links to API specification -->
    <rdf:Description rdf:about="https://www.graphresearchlabs.com/base/APIRoot">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.graphresearchlabs.com/base/hasAPI"/>
                <owl:someValuesFrom rdf:resource="https://example.com/cardinality/CardinalityTestAPIV1.0"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </rdf:Description>

    <!-- API Specification Class -->
    <owl:Class rdf:about="https://example.com/cardinality/CardinalityTestAPIV1.0">
        <rdfs:subClassOf rdf:resource="https://www.graphresearchlabs.com/base/GRLAPISpecifications"/>
        <rdfs:subClassOf rdf:nodeID="hasCardinalityResource"/>
        <skos:prefLabel>Cardinality Test API V1.0</skos:prefLabel>
        <api:apiDisplayLabel>CardinalityTestAPIV1.0</api:apiDisplayLabel>
    </owl:Class>

    <owl:Restriction rdf:nodeID="hasCardinalityResource">
        <owl:onProperty rdf:resource="https://www.graphresearchlabs.com/base/hasResourceSchema"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onClass rdf:resource="https://example.com/cardinality/CardinalityTest"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTestAPIV1.0"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="hasCardinalityResource"/>
        <api:apitag>CardinalityTest</api:apitag>
    </owl:Axiom>

    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:about="https://example.com/cardinality/minCardOne">
        <skos:prefLabel>Min Card One</skos:prefLabel>
        <skos:definition>Property with minCardinality 1</skos:definition>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://example.com/cardinality/minCardTwo">
        <skos:prefLabel>Min Card Two</skos:prefLabel>
        <skos:definition>Property with minCardinality 2</skos:definition>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://example.com/cardinality/maxCardOne">
        <skos:prefLabel>Max Card One</skos:prefLabel>
        <skos:definition>Property with maxCardinality 1</skos:definition>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://example.com/cardinality/maxCardThree">
        <skos:prefLabel>Max Card Three</skos:prefLabel>
        <skos:definition>Property with maxCardinality 3</skos:definition>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://example.com/cardinality/exactCardOne">
        <skos:prefLabel>Exact Card One</skos:prefLabel>
        <skos:definition>Property with exactCardinality 1</skos:definition>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://example.com/cardinality/exactCardTwo">
        <skos:prefLabel>Exact Card Two</skos:prefLabel>
        <skos:definition>Property with exactCardinality 2</skos:definition>
    </owl:DatatypeProperty>

    <!-- CardinalityTest Resource Class -->
    <owl:Class rdf:about="https://example.com/cardinality/CardinalityTest">
        <skos:prefLabel>Cardinality Test</skos:prefLabel>
        <skos:definition>Resource class to test cardinality restrictions.</skos:definition>

        <!-- apiID (required for resources) -->
        <rdfs:subClassOf rdf:nodeID="cardApiId"/>

        <!-- minCardinality 1 -->
        <rdfs:subClassOf rdf:nodeID="minCardOneRestr"/>

        <!-- minCardinality 2 -->
        <rdfs:subClassOf rdf:nodeID="minCardTwoRestr"/>

        <!-- maxCardinality 1 -->
        <rdfs:subClassOf rdf:nodeID="maxCardOneRestr"/>

        <!-- maxCardinality 3 -->
        <rdfs:subClassOf rdf:nodeID="maxCardThreeRestr"/>

        <!-- exactCardinality 1 -->
        <rdfs:subClassOf rdf:nodeID="exactCardOneRestr"/>

        <!-- exactCardinality 2 -->
        <rdfs:subClassOf rdf:nodeID="exactCardTwoRestr"/>
    </owl:Class>

    <!-- apiID restriction -->
    <owl:Restriction rdf:nodeID="cardApiId">
        <owl:onProperty rdf:resource="https://www.graphresearchlabs.com/base/apiID"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="cardApiId"/>
        <api:apiLabel>CardinalityTestAPIV1.0</api:apiLabel>
    </owl:Axiom>

    <!-- minCardinality 1 restriction -->
    <owl:Restriction rdf:nodeID="minCardOneRestr">
        <owl:onProperty rdf:resource="https://example.com/cardinality/minCardOne"/>
        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="minCardOneRestr"/>
        <api:apiLabel>CardinalityTestAPIV1.0</api:apiLabel>
    </owl:Axiom>

    <!-- minCardinality 2 restriction -->
    <owl:Restriction rdf:nodeID="minCardTwoRestr">
        <owl:onProperty rdf:resource="https://example.com/cardinality/minCardTwo"/>
        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="minCardTwoRestr"/>
        <api:apiLabel>CardinalityTestAPIV1.0</api:apiLabel>
    </owl:Axiom>

    <!-- maxCardinality 1 restriction -->
    <owl:Restriction rdf:nodeID="maxCardOneRestr">
        <owl:onProperty rdf:resource="https://example.com/cardinality/maxCardOne"/>
        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="maxCardOneRestr"/>
        <api:apiLabel>CardinalityTestAPIV1.0</api:apiLabel>
    </owl:Axiom>

    <!-- maxCardinality 3 restriction -->
    <owl:Restriction rdf:nodeID="maxCardThreeRestr">
        <owl:onProperty rdf:resource="https://example.com/cardinality/maxCardThree"/>
        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:maxQualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="maxCardThreeRestr"/>
        <api:apiLabel>CardinalityTestAPIV1.0</api:apiLabel>
    </owl:Axiom>

    <!-- exactCardinality 1 restriction -->
    <owl:Restriction rdf:nodeID="exactCardOneRestr">
        <owl:onProperty rdf:resource="https://example.com/cardinality/exactCardOne"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="exactCardOneRestr"/>
        <api:apiLabel>CardinalityTestAPIV1.0</api:apiLabel>
    </owl:Axiom>

    <!-- exactCardinality 2 restriction -->
    <owl:Restriction rdf:nodeID="exactCardTwoRestr">
        <owl:onProperty rdf:resource="https://example.com/cardinality/exactCardTwo"/>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:qualifiedCardinality>
        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://example.com/cardinality/CardinalityTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="exactCardTwoRestr"/>
        <api:apiLabel>CardinalityTestAPIV1.0</api:apiLabel>
    </owl:Axiom>

</rdf:RDF>
