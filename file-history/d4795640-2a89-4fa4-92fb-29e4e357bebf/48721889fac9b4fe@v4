package kakuro;

import java.util.ArrayList;
import java.util.List;
import java.util.stream.IntStream;
import java.util.stream.Stream;

/** Immutable kakuro grid holding cells and precomputed runs. */
public final class Grid {
    private final Cell[][] cells;
    private final int rows;
    private final int cols;
    private final List<Run> runs;

    public Grid(Cell[][] cells) {
        this.cells = cells;
        this.rows = cells.length;
        this.cols = cells[0].length;
        this.runs = extractRuns();
    }

    /** Returns the cell at the given row and column. */
    public Cell get(int row, int col) {
        return cells[row][col];
    }

    public int rows() { return rows; }

    public int cols() { return cols; }

    /** Returns all runs (across and down) extracted from clue cells. */
    public List<Run> runs() { return runs; }

    /** Returns a stream of all positions in the grid. */
    public Stream<Position> positions() {
        return IntStream.range(0, rows).boxed()
                .flatMap(r -> IntStream.range(0, cols)
                        .mapToObj(c -> new Position(r, c)));
    }

    private List<Run> extractRuns() {
        return positions()
                .filter(p -> cells[p.row()][p.col()] instanceof Cell.Clue)
                .flatMap(p -> runsFrom((Cell.Clue) cells[p.row()][p.col()], p))
                .toList();
    }

    private Stream<Run> runsFrom(Cell.Clue clue, Position pos) {
        var builder = Stream.<Run>builder();
        if (clue.across() > 0) builder.add(buildRun(clue.across(), pos.row(), pos.col(), 0, 1));
        if (clue.down() > 0) builder.add(buildRun(clue.down(), pos.row(), pos.col(), 1, 0));
        return builder.build();
    }

    private Run buildRun(int target, int r, int c, int dr, int dc) {
        var positions = new ArrayList<Position>();
        int nr = r + dr;
        int nc = c + dc;
        while (nr < rows && nc < cols && cells[nr][nc] instanceof Cell.Empty) {
            positions.add(new Position(nr, nc));
            nr += dr;
            nc += dc;
        }
        return new Run(target, List.copyOf(positions));
    }
}
